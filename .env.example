# مثال على ملف Environment Variables
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك

# عنوان API الخاص بالـ Backend
VITE_API_URL=http://localhost/refaq/backend

# تعطيل console.log في الإنتاج (true/false)
VITE_DISABLE_CONSOLE=false

# بيئة التشغيل (development/production)
NODE_ENV=development
